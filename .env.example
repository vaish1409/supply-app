# Copy this file to .env and fill in real values before running.

PORT=3000

# On Render with a persistent disk, set this to the disk mount path (/var/data).
# Leave it unset locally to keep data.sqlite and uploads/ in the project folder.
STORAGE_DIR=

# Used to sign admin login tokens — set this to a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# First-run admin account (only used the first time the database is created).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Razorpay keys — required only for the "Pay online" option.
# Leave blank to keep online payment disabled (COD / advance still work).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
